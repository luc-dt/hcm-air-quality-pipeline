# ============================================================
# HCM Air Quality Pipeline — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# The .env file is gitignored and must NEVER be committed.
#
#   cp .env.example .env
# ============================================================

# Path to your GCP service account JSON key.
# Terraform and the Google Cloud SDK will both use this automatically.
GOOGLE_APPLICATION_CREDENTIALS=./keys/hcm-pipeline-sa.json

# Your GCP project ID
GOOGLE_CLOUD_PROJECT=de-zoomcamp-2026-486008

# API TOKEN
AQICN_API_TOKEN=your_token_here
